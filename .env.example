# Copy to .env and fill in. Never commit .env.

# === OpenAI (only needed for LLM pseudo-labeling on MSP-PODCAST) ===
OPENAI_API_KEY=sk-...

# === Weights & Biases (optional) ===
# Leave blank to disable wandb (the trainer auto-falls back to TensorBoard).
WANDB_API_KEY=
WANDB_PROJECT=merits-l-text
WANDB_ENTITY=

# === HuggingFace cache (optional, set to a fast disk on cloud GPU) ===
HF_HOME=/workspace/.cache/huggingface
TRANSFORMERS_CACHE=/workspace/.cache/huggingface/transformers

# === Dataset roots (adjust on cloud) ===
IEMOCAP_ROOT=/workspace/datasets/IEMOCAP_full_release
MELD_ROOT=/workspace/datasets/MELD
MOSI_ROOT=/workspace/datasets/CMU-MOSI
MSP_PODCAST_ROOT=/workspace/datasets/MSP-PODCAST
